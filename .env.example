# Claude Telegram Bot - Environment Configuration

# ==============================================================================
# REQUIRED
# ==============================================================================

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Comma-separated Telegram user IDs allowed to use the bot
# Find your ID: message @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=123456789

# ==============================================================================
# RECOMMENDED
# ==============================================================================

# Working directory where Claude runs (loads CLAUDE.md, skills, MCP config)
CLAUDE_WORKING_DIR=/Users/yourname/personal

# OpenAI API key for voice message transcription
# Without this, voice messages won't work
OPENAI_API_KEY=sk-...

# ==============================================================================
# OPTIONAL - Security
# ==============================================================================

# Comma-separated paths Claude can access
# Default: working dir, ~/Documents, ~/Downloads, ~/Desktop, ~/.claude
# Note: Setting this OVERRIDES defaults. Include ~/.claude for plan mode to work.
# ALLOWED_PATHS=/Users/yourname/personal,/Users/yourname/projects,/Users/yourname/.claude

# Rate limiting (token bucket)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=20
# RATE_LIMIT_WINDOW=60

# ==============================================================================
# OPTIONAL - Claude Authentication
# ==============================================================================

# API key for environments without Claude Code CLI auth
# Get from: https://console.anthropic.com/
# Note: API usage is billed per token - CLI auth is more cost-effective
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Path to Claude CLI (auto-detected from PATH by default)
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# ==============================================================================
# OPTIONAL - Extended Thinking
# ==============================================================================

# Keywords that trigger extended thinking (comma-separated, case-insensitive)
# THINKING_KEYWORDS=think,pensa,ragiona

# Keywords that trigger deep thinking (50k tokens)
# THINKING_DEEP_KEYWORDS=ultrathink,think hard,pensa bene

# ==============================================================================
# OPTIONAL - Voice Transcription
# ==============================================================================

# Path to a text file with additional context for voice transcription
# (names, technical terms, etc. — keeps personal context outside this repo)
# TRANSCRIPTION_CONTEXT_FILE=/path/to/transcription-context.txt

# ==============================================================================
# OPTIONAL - Logging
# ==============================================================================

# Audit log path
# AUDIT_LOG_PATH=/tmp/claude-telegram-audit.log

# Output audit logs as JSON (default: human-readable)
# AUDIT_LOG_JSON=false

# ==============================================================================
# OPTIONAL - Group chat
# ==============================================================================

# Group chat ID nếu bot dùng cho 1 group cố định (cron jobs gửi vào group thay
# vì chat riêng). Lấy bằng cách: tắt privacy mode trong @BotFather, add bot vào
# group, gửi 1 tin trong group, đọc /tmp/claude-telegram-bot-*.log để thấy
# `[group-filter] chat_id=...`.
# TELEGRAM_GROUP_CHAT_ID=-1001234567890

# ==============================================================================
# OPTIONAL - UX
# ==============================================================================

# Quiet mode: ẩn mọi tool/thinking/intermediate streaming. Bot chỉ gửi 1 tin
# "🤔 đang xử lý..." khi bắt đầu, edit thành câu trả lời cuối khi xong.
# Mặc định false → stream từng tool call ra Telegram (verbose, hữu ích để debug).
# QUIET_MODE=true

# ==============================================================================
# OPTIONAL - Multi-instance (chạy nhiều bot song song)
# ==============================================================================

# Khi chạy 2+ bot trên cùng máy, các path /tmp/* hardcoded sẽ đụng nhau. Override
# từng path để tách. Đặt suffix theo tên bot (vd: -teamA, -teamB).
# SESSION_FILE=/tmp/claude-telegram-session.json
# RESTART_FILE=/tmp/claude-telegram-restart.json
# TEMP_DIR=/tmp/telegram-bot

# ==============================================================================
# OPTIONAL - whisper.cpp (local STT, Windows/Linux/Mac, không cần API key)
# ==============================================================================
#
# Ưu tiên cao nhất. Cần cài sẵn:
#   1. whisper.cpp: https://github.com/ggml-org/whisper.cpp
#      → Download release hoặc tự build → lưu vào E:\whisper\
#   2. ffmpeg: https://ffmpeg.org/download.html (thêm vào PATH)
#   3. Model: tải tại https://huggingface.co/ggerganov/whisper.cpp/tree/main
#      → medium.bin (~1.5GB) khuyên dùng cho tiếng Việt
#
# Windows:
# WHISPER_CPP_PATH=E:\whisper\whisper-cli.exe
# WHISPER_CPP_MODEL=E:\whisper\models\ggml-medium.bin
# WHISPER_CPP_LANG=vi
# WHISPER_CPP_THREADS=4

# ==============================================================================
# OPTIONAL - Local Whisper (Apple Silicon, MLX — legacy)
# ==============================================================================

# Đường dẫn đến shell script gọi mlx-whisper local (thay cho OpenAI API).
# WHISPER_SCRIPT_PATH=/path/to/process_audio.sh

# ==============================================================================
# OPTIONAL - Document parsing
# ==============================================================================

# Đường dẫn đến markitdown CLI (PDF/DOCX/XLSX/PPTX → markdown).
# Mặc định gọi `markitdown` qua PATH. Cài: `pipx install markitdown`.
# MARKITDOWN_CLI=/path/to/venv/bin/markitdown
